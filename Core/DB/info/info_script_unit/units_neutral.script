modInt unic_unit_giant_frog_passive_1
{ 
	CurrentUnitData ( fullStacksBase, "fullStacks" )
	CurrentUnitData ( fullStacksTemp, "tempFullStacks" )
	Add ( fullStacks, fullStacksBase, fullStacksTemp )
	CurrentUnitData ( startStacks, "startBattleFullStacks" )

	CurrentUnitConfig ( buffSid, "defaultAttacks[0].damageDealer.buff.sid" )

	Add ( currentStacks, fullStacks, 1 )
	Add ( maxStacks, startStacks, 1 )
	
	DbBuff( buffDataBase, buffSid, "actions[0].damageDealer.minBaseDmg" )
	DbBuff( buffData, buffSid, "actions[0].damageDealer.minStackDmg" )

	Mul ( MulData, currentStacks, buffData )	
	Add ( return, MulData, buffDataBase )
}

