string unic_unit_lich_dragon_active_1
{ 
	CurrentUnitData ( finalHealingBonusPercent, "unit.stats.finalHealingBonusPercent" )	
	
	Mul ( finalHealingBonusPercentAmount, "100", finalHealingBonusPercent )
	Add ( finalHeal, "100", finalHealingBonusPercentAmount )

	Text( return, finalHeal )
}

